rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.role in ['super_admin','admin']; }
    function isStaff() { return signedIn() && request.auth.token.role in ['super_admin','admin','billing_staff']; }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId}/products/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /stores/{storeId}/orders/{id} {
      allow create: if true;
      allow read: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /stores/{storeId}/customers/{id} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /stores/{storeId}/customers/{customerId}/ledger/{entryId} {
      allow read, write: if isStaff();
    }

    match /stores/{storeId}/riderLocations/{id} {
      allow write: if true;
      allow read: if isStaff();
    }

    match /notificationTokens/{id} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }
  }
}
